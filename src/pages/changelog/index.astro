---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Changelog"
  description="A lightweight changelog for updates to Practicioner Blog."
>
  <section class="intro">
    <h1>Changelog</h1>
    <p class="lead">A lightweight record of site updates and learning milestones.</p>
  </section>

  <section aria-labelledby="latest">
    <h2 id="latest">Latest</h2>
    <p>Astro migration scaffold added with Markdown-powered learning notes.</p>
  </section>
</BaseLayout>
