---
import BaseLayout from '../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const notesHref = base + '/notes/';
const changelogHref = base + '/changelog/';
---

<BaseLayout
  title="Practicioner Blog"
  description="A personal site for QA practice, learning notes, and project changelogs."
>
  <section class="intro">
    <h1>Practicioner Blog</h1>
    <p class="lead">
      A personal workspace for QA practice, product quality thinking, and notes from the field.
    </p>
  </section>

  <section aria-labelledby="site-sections">
    <h2 id="site-sections">Sections</h2>
    <ul class="link-list">
      <li class="link-item">
        <a href={notesHref}>Learning Notes</a>
        <p>Markdown notes on QA frameworks, AI testing, and other topics worth keeping close.</p>
      </li>
      <li class="link-item">
        <a href={changelogHref}>Changelog</a>
        <p>A lightweight record of site updates and learning milestones.</p>
      </li>
    </ul>
  </section>
</BaseLayout>
