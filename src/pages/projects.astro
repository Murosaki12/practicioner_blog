---
import BaseLayout from '../layouts/BaseLayout.astro';

const PROJECTS = [
  {
    name: 'Duke Hoang — Notes',
    blurb: 'This site. A personal blog for learning notes on QA, AI, and software craft. Built with Astro, MDX, and Keystatic for easy editing.',
    status: 'ongoing',
    year: '2026',
    tags: ['astro', 'mdx', 'design'],
    link: '/',
    linkLabel: 'You\'re here',
  },
  {
    name: 'QA Framework Notes',
    blurb: 'A living document on risk-based QA — FMEA, test strategy, exit criteria, and the mental models I use day-to-day.',
    status: 'ongoing',
    year: '2026',
    tags: ['qa', 'writing'],
    link: '/notes/qa-framework/',
    linkLabel: 'Read note →',
  },
  {
    name: 'AI for QA',
    blurb: 'Long-form notes on LLMs, RAG, agents, and how to test AI products — written for QA people, not data scientists.',
    status: 'ongoing',
    year: '2026',
    tags: ['ai', 'qa', 'writing'],
    link: '/notes/ai-for-qa/',
    linkLabel: 'Read note →',
  },
  {
    name: 'Prompt Regression Suite',
    blurb: 'Exploring a small, opinionated approach to catching prompt drift between model versions — golden inputs, judge prompts, and LLM-as-judge tradeoffs.',
    status: 'experiment',
    year: '2026',
    tags: ['ai', 'testing', 'llms'],
    link: null,
    linkLabel: 'In progress',
  },
];

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout
  title="Projects"
  description="Things Duke Hoang is building or has built."
  activePage="projects"
>
  <div class="container">
    <section class="hero fade-in">
      <span class="eyebrow"><span class="dot"></span>Work</span>
      <h1>Projects</h1>
      <p class="lead">
        Small things I'm building or thinking through &mdash; mostly weekend experiments and ongoing learning projects.
      </p>
    </section>

    <section class="section fade-in fade-in-1">
      <ul class="project-list">
        {PROJECTS.map((p, i) => (
          <li class={'project-card fade-in fade-in-' + Math.min(i + 1, 3)}>
            <div class="project-meta">
              <span class={'project-status status-' + p.status}>{p.status}</span>
              <span class="project-year">{p.year}</span>
            </div>
            <div class="project-name">{p.name}</div>
            <p class="project-blurb">{p.blurb}</p>
            <div class="project-foot">
              <div class="project-tags">
                {p.tags.map(t => <span class="tag">#{t}</span>)}
              </div>
              {p.link
                ? <a class="project-link" href={base + p.link}>{p.linkLabel}</a>
                : <span class="project-link" style="color:var(--faint);font-family:var(--font-mono);font-size:0.74rem;text-transform:uppercase;letter-spacing:0.06em">{p.linkLabel}</span>
              }
            </div>
          </li>
        ))}
      </ul>
    </section>
  </div>
</BaseLayout>
