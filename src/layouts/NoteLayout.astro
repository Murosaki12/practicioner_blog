---
import BaseLayout from './BaseLayout.astro';

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  title: string;
  description?: string;
  pubDate: Date;
  tags?: string[];
  readTime?: number;
  headings?: Heading[];
}

const { title, description, pubDate, tags = [], readTime = 5, headings = [] } = Astro.props;

const formattedDate = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const tocItems = headings.filter(h => h.depth === 2 || h.depth === 3);
---

<BaseLayout title={title} description={description} activePage="notes">
  <div class="read-progress" id="read-progress-bar"></div>

  <div class="container-wide">
    <div class={"article-layout" + (tocItems.length > 0 ? '' : ' no-toc')}>
      {tocItems.length > 0 && (
        <aside class="article-toc" id="article-toc">
          <div class="article-toc-label">On this page</div>
          <ol>
            {tocItems.map(h => (
              <li style={h.depth === 3 ? 'padding-left:0.75rem' : ''}>
                <a href={'#' + h.slug} data-toc-id={h.slug}>{h.text}</a>
              </li>
            ))}
          </ol>
        </aside>
      )}

      <article class="fade-in">
        <header class="article-header">
          <div class="meta-row">
            <span class="eyebrow"><span class="dot"></span>Learning note</span>
            <span class="meta-sep">·</span>
            <span>{formattedDate}</span>
            <span class="meta-sep">·</span>
            <span style="display:inline-flex;align-items:center;gap:4px">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg>
              {readTime} min read
            </span>
          </div>
          <h1>{title}</h1>
          {description && <p class="desc">{description}</p>}
          {tags.length > 0 && (
            <div class="note-tags" style="margin-top:1rem">
              {tags.map(t => <span class="tag">#{t}</span>)}
            </div>
          )}
        </header>

        <div class="prose">
          <slot />
        </div>

        <div class="article-foot">
          <a class="back-link" href="../">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
            All notes
          </a>
          <a class="back-link" href="../../">
            Home
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>
      </article>
    </div>
  </div>
</BaseLayout>

<style>
  .no-toc { grid-template-columns: 1fr; }
</style>

<script is:inline>
  (function() {
    // ── Reading progress bar ─────────────────────────────────
    var bar = document.getElementById('read-progress-bar') || document.getElementById('read-progress');
    if (bar) {
      function updateProgress() {
        var h = document.documentElement;
        var scrolled = h.scrollTop || document.body.scrollTop;
        var total = h.scrollHeight - h.clientHeight;
        bar.style.width = (total > 0 ? Math.min(100, scrolled / total * 100) : 0) + '%';
      }
      window.addEventListener('scroll', updateProgress, { passive: true });
      updateProgress();
    }

    // ── Active TOC highlight ─────────────────────────────────
    var tocLinks = document.querySelectorAll('[data-toc-id]');
    if (tocLinks.length) {
      var ids = Array.from(tocLinks).map(function(a) { return a.getAttribute('data-toc-id'); });
      function updateToc() {
        var current = ids[0];
        for (var i = 0; i < ids.length; i++) {
          var el = document.getElementById(ids[i]);
          if (el && el.getBoundingClientRect().top < 120) current = ids[i];
        }
        tocLinks.forEach(function(a) {
          a.classList.toggle('active', a.getAttribute('data-toc-id') === current);
        });
      }
      window.addEventListener('scroll', updateToc, { passive: true });
      updateToc();
    }
  })();
</script>
